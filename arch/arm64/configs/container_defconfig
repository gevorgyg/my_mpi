# Minimal arm64 config for macOS container tool + MPI syscalls
#
# Usage:
#   make ARCH=arm64 container_defconfig
#   make ARCH=arm64 -j$(nproc) Image

# Base
CONFIG_ARM64=y
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_NR_CPUS=8
CONFIG_HZ_250=y
CONFIG_NO_HZ_IDLE=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_PREEMPT=y
CONFIG_PRINTK=y
CONFIG_BUG=y
CONFIG_SYSCTL=y
CONFIG_POSIX_MQUEUE=y
CONFIG_MULTIUSER=y
CONFIG_SYSFS=y
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_TMPFS=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_AIO=y
CONFIG_IO_URING=y
CONFIG_ADVISE_SYSCALLS=y

# TTY / Console
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# Block layer
CONFIG_BLOCK=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_OVERLAY_FS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_VFAT_FS=y
CONFIG_FUSE_FS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# 9P (host filesystem sharing)
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_9P_FS=y
CONFIG_9P_FS_POSIX_ACL=y

# Virtio (container VM transport)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_VIRTIO_FS=y
CONFIG_VIRTIO_INPUT=y

# PCI
CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y

# Networking (basic)
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_NETDEVICES=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_NETFILTER=y

# Memory
CONFIG_SLAB=y
CONFIG_MEMORY_HOTPLUG=y
CONFIG_MEMORY_HOTREMOVE=y

# Modules (optional, for flexibility)
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y

# cgroups (container needs)
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_PIDS=y
CONFIG_MEMCG=y
CONFIG_CPUSETS=y

# Namespaces (container needs)
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_MNT_NS=y

# Disable unnecessary stuff
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set
# CONFIG_SOUND is not set
# CONFIG_USB is not set
# CONFIG_INPUT_MOUSE is not set
# CONFIG_INPUT_KEYBOARD is not set
# CONFIG_HID is not set
